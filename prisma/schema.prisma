generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Cadastro de Membros geral (O que fizemos na tela anterior)
model Membro {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  rga       String     @unique
  funcoes   String[]   // Todas as habilidades dele (Back-End, Designer, etc.)
  createdAt DateTime   @default(now())
  
  // Relacionamento: Um membro pode estar em várias alocações
  alocacoes Alocacao[]
}

// 2. Cadastro de Projetos (Pronto para a sua próxima tela do Figma!)
model Projeto {
  id          String     @id @default(uuid())
  nome        String
  descricao   String?
  status      String     @default("Criado") // Valores possíveis: "Criado", "Em Progresso", "Concluido"
  dataLimite  DateTime?
  createdAt   DateTime   @default(now())

  alocacoes   Alocacao[]
}

// 3. Tabela Intermediária: Alocação
model Alocacao {
  id        String   @id @default(uuid())
  
  // Quem é o membro e qual projeto
  membroId  String
  membro    Membro   @relation(fields: [membroId], references: [id], onDelete: Cascade)
  
  projetoId String
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  // A REGRA: Apenas UMA função específica para este membro NESTE projeto
  funcaoNoProjeto String 

  createdAt DateTime @default(now())

  // Garante que o mesmo membro não seja alocado duas vezes no mesmo projeto
  @@unique([membroId, projetoId]) 
}

// Adicione este modelo no final do seu arquivo schema.prisma existente

model Diretor {
  id        String   @id @default(uuid())
  nome      String
  rga       String   @unique
  email     String   @unique
  login     String   @unique
  senha     String   // No futuro vamos criptografar isso para segurança!
  funcoes   String[] // Array para armazenar as funções marcadas nos checkboxes dele
  createdAt DateTime @default(now())
}
